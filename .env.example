# Optional server-only Xiaomi Weather proxy configuration.
# Keep real values in Vercel Development/Preview or an ignored .env.local file.
XIAOMI_WEATHER_BASE_URL=
XIAOMI_WEATHER_APP_KEY=
XIAOMI_WEATHER_SIGN=
XIAOMI_WEATHER_APP_VERSION=
XIAOMI_WEATHER_ROM_VERSION=
XIAOMI_WEATHER_DEVICE=
XIAOMI_WEATHER_OAID=

# Non-secret client feature gate. Keep false for Production in Weather W3.
VITE_XIAOMI_WEATHER_ENABLED=false
