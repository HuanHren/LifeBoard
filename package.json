{
  "name": "lifeboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:unit:ci": "vitest run",
    "test:weather-xiaomi:ci": "vitest run --config vitest.xiaomi.config.js",
    "test:weather-xiaomi-provider:ci": "vitest run --config vitest.xiaomi-provider.config.ts",
    "test:weather-w3:ci": "vitest run --config vitest.weather-w3.config.ts",
    "test:weather-w4:ci": "vitest run --config vitest.weather-w4.config.ts",
    "test:weather-w5:ci": "vitest run --config vitest.weather-w5.config.ts",
    "test:weather-display-hotfix:ci": "vitest run --config vitest.weather-display-hotfix.config.ts",
    "test:weather-current-location-xiaomi:ci": "vitest run --config vitest.weather-current-location-xiaomi.config.ts",
    "verify:weather-xiaomi": "node scripts/verify-xiaomi-weather-proxy.mjs",
    "qa:a11y:routes": "node scripts/qa-route-a11y.mjs",
    "qa:a11y:routes:ci": "node scripts/qa-route-a11y.mjs --ci",
    "qa:a11y:routes:json": "node scripts/qa-route-a11y.mjs --json",
    "qa:a11y:routes:json:file": "node scripts/qa-route-a11y.mjs --json --output .qa/route-a11y-summary.json",
    "qa:screenshots": "node scripts/qa-route-screenshots.mjs",
    "qa:screenshots:ci": "node scripts/qa-route-screenshots.mjs --ci",
    "qa:weather-w4": "node scripts/qa-weather-w4.mjs",
    "qa:weather-w5": "node scripts/qa-weather-w5.mjs",
    "qa:weather-display-hotfix": "node scripts/qa-weather-display-hotfix.mjs",
    "qa:weather-current-location-xiaomi": "node scripts/qa-weather-current-location-xiaomi.mjs",
    "verify:weather-w4:preview": "node scripts/verify-weather-w4-preview.mjs",
    "verify:weather-w5:preview": "node scripts/verify-weather-w5-preview.mjs",
    "qa:design": "npm run build && npm run qa:screenshots",
    "qa": "npm run build && npm run qa:a11y:routes"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "pinia": "^3.0.4",
    "pixi.js": "8.19.0",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.2.8"
  }
}
